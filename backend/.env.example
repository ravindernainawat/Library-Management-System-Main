# BookSphere Environment Configuration Template
# Copy this file to a new file named '.env' in this directory and fill in the values.
# NEVER commit or share the actual '.env' file!

# Port to run the backend API server on
PORT=5000

# Connection URI for MongoDB. If blank or unreachable, the server will fallback 
# automatically to a persistent local memory server stored in './data/db'.
MONGODB_URI=mongodb://127.0.0.1:27017/booksphere

# Gmail SMTP Configuration for Email Notifications
SMTP_ENABLED=false
SMTP_EMAIL=your-gmail-address@gmail.com
# For Gmail, create an App Password: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Google Gemini API Key for the Library AI Assistant Chatbot
GEMINI_API_KEY=AIzaSy...your-actual-api-key-here...

# JSON Web Token (JWT) secret used for signing and validating session tokens.
# IMPORTANT: Change this to a long random secret string in production!
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# CORS allowed origins (comma-separated list of frontends allowed to request the API)
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000,http://127.0.0.1:5000,http://localhost:5173
